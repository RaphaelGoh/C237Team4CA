<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Gangnam Spice</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Noto Sans KR', sans-serif;
      background-color: #fff8f5;
      margin: 0;
      padding: 0;
    }

    .navbar {
      background-color: #fff !important;
      border-bottom: 1px solid #ddd;
    }

    .navbar-brand {
      font-weight: bold;
      color: #dc3545 !important;
    }

    .hero-section {
      position: relative;
      width: 100%;
      height: 80vh;
      overflow: hidden;
    }

    .hero-section img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-buttons {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
    }

    .hero-buttons h2 {
      font-size: 2.3rem;
      color: white;
      font-weight: bold;
      margin-bottom: 350px;
      text-shadow: 2px 2px 6px rgba(0,0,0,0.7);
    }

    .btn-custom {
      font-size: 1rem;
      padding: 12px 20px;
      margin: 5px;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
      <a class="navbar-brand" href="/">Gangnam Spice</a>
    </div>
  </nav>

  <div class="hero-section">
    <img src="images/indeximage.jpg" alt="Korean Food Banner">
    <% if (!user) { %>
    <div class="hero-buttons">
      <h2>어서 오세요! (Welcome!)</h2>
      <a href="/login" class="btn btn-danger btn-custom">로그인 (Login)</a>
      <a href="/signup" class="btn btn-success btn-custom">회원가입 (Signup)</a>
    </div>
    <% } %>
  </div>
</body>
</html>




